# ============================================
# DINHEIRIZE - VARIÁVEIS DE AMBIENTE
# ============================================
# Copie este arquivo para .env.local e preencha os valores

# Resend (Email Marketing)
RESEND_API_KEY=re_XXXXXXXX
RESEND_SEGMENT_WAITLIST_ID=      # ID do segment "Lista de Espera" (rodar: npm run setup:segments)
RESEND_SEGMENT_CUSTOMERS_ID=     # ID do segment "Clientes Ativos"

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXX
STRIPE_SECRET_KEY=sk_test_XXXXXXXX
STRIPE_PRICE_ID=price_XXXXXXXX   # Price ID do plano WhatsApp
STRIPE_COUPON_LAUNCH990=LAUNCH990 # Coupon ID no Stripe
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXX

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyXXXXXXXX
SUPABASE_SERVICE_ROLE_KEY=eyXXXXXXXX

# App Config
NEXT_PUBLIC_APP_URL=http://localhost:3000
